# Discord webhook URL (required)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# LLM provider — choose 'gemini' or 'openai' (default: gemini)
SUMMARY_PROVIDER=gemini

# API key for the chosen provider (only the relevant one is required)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Comma-separated YouTube channel handles to monitor (required)
CHANNELS=@YourFirstChannel,@YourSecondChannel

# Optional: override model names
# GEMINI_MODEL=gemini-2.5-flash-lite
# OPENAI_MODEL=gpt-4.1-mini

# Optional: data directory (default: /data)
# DATA_DIR=/data
